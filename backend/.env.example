# Database
DATABASE_URL=""

# JWT
JWT_SECRET="your-jwt-secret-here"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Storage (S3 / MinIO / Cloudflare R2)
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="ticket-attachments"
STORAGE_REGION="ap-southeast-1"
STORAGE_PRESIGNED_URL_EXPIRES=3600

# Attachments: local = backend/uploads + /api/files | firebase = Firebase Storage + signed URLs
ATTACHMENT_STORAGE=local
# เมื่อ ATTACHMENT_STORAGE=firebase — ตั้ง bucket (หรือปล่อยว่างแล้วใช้ {project_id}.appspot.com จากไฟล์ credential)
FIREBASE_STORAGE_BUCKET=""
# Path ไปยัง service account JSON (แนะนำให้เก็บนอก repo และชี้ absolute path)
GOOGLE_APPLICATION_CREDENTIALS="../keys/your-firebase-adminsdk.json"

# App
PORT=3001
NODE_ENV=development
BACKEND_URL="http://localhost:3001"
# Production: Swagger ปิดโดยอัตโนมัติ — เปิดเฉพาะเมื่อ ENABLE_SWAGGER=true
# ENABLE_SWAGGER=true
